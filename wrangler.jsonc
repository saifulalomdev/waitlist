{
	"main": "dist/_worker.js/index.js",
	"name": "waitlist",
	"compatibility_date": "2026-03-03",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "waitlist",
			"database_id": "41144ecb-211b-4f7f-bd58-115ed6b681c1",
			"remote": true,
			"migrations_dir": "./drizzle"
		}
	],
	"observability": {
		"enabled": true
	}
}